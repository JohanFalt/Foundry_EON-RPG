<div class="eon-ccw-wrapper">
  <aside class="eon-ccw-sidebar">
    <div class="eon-ccw-summary-title">{{localize "eon.wizard.sidebarOversiktRubrik"}}</div>
    <p class="eon-ccw-summary-hint">{{localize "eon.wizard.sidebarHint"}}</p>

    <div class="eon-ccw-summary-section">
      <div class="eon-ccw-summary-title">{{localize "eon.wizard.sidebarHandelser"}}</div>
      <p class="eon-ccw-summary-hint">{{localize "eon.wizard.sidebarHandelserHint"}}</p>
      <div class="eon-ccw-datagrid eon-ccw-datagrid--summary-2">
        {{#each handelseOvRows}}
        <div class="eon-ccw-datagrid__row">
          <div class="eon-ccw-datagrid__cell">{{label}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ht_{{key}}" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_ht_{{key}}" value="{{value}}" min="0" step="1" data-dtype="Number" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ht_{{key}}" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    
    <div class="eon-ccw-summary-section">
      <div class="eon-ccw-summary-title">{{localize "eon.wizard.sidebarGrundegenskaper"}}</div>
      <p class="eon-ccw-summary-hint">{{localize "eon.wizard.sidebarGrundegenskaperHint"}}</p>
      <div class="eon-ccw-datagrid eon-ccw-datagrid--summary-attr">
        <div class="eon-ccw-datagrid__row eon-ccw-datagrid__row--head">
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr">{{localize "eon.sheets.item.attribut"}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr">{{localize "eon.sheets.actor.grund"}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr">{{localize "eon.sheets.item.bonus"}}</div>
        </div>
        {{#each harleddaRowsOv}}
        <div class="eon-ccw-datagrid__row">
          <div class="eon-ccw-datagrid__cell">{{label}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_attr_{{key}}_g" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_ov_attr_{{key}}_g" value="{{grund}}" step="1" data-dtype="Number" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_attr_{{key}}_g" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_attr_{{key}}_b" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_ov_attr_{{key}}_b" value="{{bonus}}" step="1" data-dtype="Number" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_attr_{{key}}_b" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
        </div>
        {{/each}}
        <div class="eon-ccw-datagrid__row eon-ccw-datagrid__row--extra-attr-poang">
          <div class="eon-ccw-datagrid__cell">{{localize "eon.wizard.valfriaAttributPoangLabel"}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num"></div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_extra_attr_poang" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_extra_attr_poang" value="{{wizardDraft.extraAttributPoang}}" step="1" data-dtype="Number" aria-label="{{localize 'eon.wizard.valfriaAttributPoangLabel'}}" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_extra_attr_poang" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="eon-ccw-summary-section">
      <div class="eon-ccw-summary-title">{{localize "eon.wizard.sidebarEnheter"}}</div>
      <p class="eon-ccw-summary-hint">{{localize "eon.wizard.sidebarEnheterHint"}}</p>
      <div class="eon-ccw-datagrid eon-ccw-datagrid--summary-2">
        {{#each enhetRowsOv}}
        <div class="eon-ccw-datagrid__row">
          <div class="eon-ccw-datagrid__cell">{{label}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_e_{{key}}" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_ov_e_{{key}}" value="{{value}}" min="0" step="1" data-dtype="Number" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_ov_e_{{key}}" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    <div class="eon-ccw-summary-section">
      <div class="eon-ccw-summary-title">{{localize "eon.wizard.sidebarPaketSteg13"}}</div>
      <div class="eon-ccw-datagrid eon-ccw-datagrid--summary-2">
        {{#each paketRows}}
        <div class="eon-ccw-datagrid__row">
          <div class="eon-ccw-datagrid__cell">{{label}}</div>
          <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--num">
            <div class="eon-ccw-num-tiny-stepper" role="group">
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_pkt_{{key}}" data-ccw-step-delta="-1" title="{{localize 'eon.wizard.attrStepDown'}}" aria-label="{{localize 'eon.wizard.attrStepDown'}}">−</button>
              <input type="number" class="eon-ccw-num-tiny" name="ccw_pkt_{{key}}" value="{{value}}" min="0" step="1" data-dtype="Number" />
              <button type="button" class="eon-ccw-num-step-btn" tabindex="-1" data-action="ccwHarleddOvStep" data-ccw-step-target="ccw_pkt_{{key}}" data-ccw-step-delta="1" title="{{localize 'eon.wizard.attrStepUp'}}" aria-label="{{localize 'eon.wizard.attrStepUp'}}">+</button>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </aside>

  <div class="eon-ccw-main">
    <header class="eon-ccw-header">{{localize "eon.wizard.mainHeaderSubtitle"}}</header>
    <div class="eon-ccw-tabs" role="tablist">
      <button type="button" class="eon-ccw-tab {{#if tabVal}}active{{/if}}" data-action="ccwTab" data-tab="val">{{localize "eon.wizard.tabVal"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabHandelser}}active{{/if}}" data-action="ccwTab" data-tab="handelser">{{localize "eon.wizard.tabHandelser"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabGrundegenskaper}}active{{/if}}" data-action="ccwTab" data-tab="grundegenskaper">{{localize "eon.wizard.tabGrundegenskaper"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabFardigheter}}active{{/if}}" data-action="ccwTab" data-tab="fardigheter">{{localize "eon.wizard.tabFardigheter"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabSprak}}active{{/if}}" data-action="ccwTab" data-tab="sprak">{{localize "eon.wizard.tabSprak"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabKaraktarsdrag}}active{{/if}}" data-action="ccwTab" data-tab="karaktarsdrag">{{localize "eon.wizard.tabKaraktarsdrag"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabNamnDetaljer}}active{{/if}}" data-action="ccwTab" data-tab="namnDetaljer">{{localize "eon.wizard.tabNamnDetaljer"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabUtrustning}}active{{/if}}" data-action="ccwTab" data-tab="utrustning">{{localize "eon.wizard.tabUtrustning"}}</button>
      <button type="button" class="eon-ccw-tab {{#if tabMystik}}active{{/if}}" data-action="ccwTab" data-tab="mystik">{{localize "eon.wizard.tabMystik"}}</button>
    </div>

    <div class="eon-ccw-content">
      {{#if tabVal}}
      <div class="eon-ccw-panel">
        <div class="eon-ccw-section">
          <div class="eon-ccw-section-title"><span class="eon-ccw-step-num">1</span>{{localize "eon.wizard.stegRollpersonen"}}</div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
            <label class="eon-ccw-label" for="ccw_actor_name">{{localize "eon.sheets.actor.namn"}}</label>
            <input type="text" id="ccw_actor_name" name="ccw_actor_name" value="{{actorName}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
            <label class="eon-ccw-label" for="ccw_koncept">{{localize "eon.sheets.actor.koncept"}}</label>
            <input type="text" id="ccw_koncept" name="ccw_koncept" value="{{wizardDraft.koncept}}" />
          </div>
        </div>
        <div class="eon-ccw-section">
          <div class="eon-ccw-section-title">{{localize "eon.wizard.stegVal26"}}</div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-num">2</span><label class="eon-ccw-label" for="ccw_hemland">{{localize "eon.sheets.actor.hemland"}}</label>
            <input type="text" id="ccw_hemland" name="ccw_hemland" value="{{wizardDraft.hemland}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-num">3</span><label class="eon-ccw-label" for="ccw_bakgrund">{{localize "eon.sheets.nav.bio"}}</label>
            <input type="text" id="ccw_bakgrund" name="ccw_bakgrund" value="{{wizardDraft.bakgrund}}" />
          </div>
          <input type="hidden" name="ccw_har_kulturfolkslag" value="{{#if wizardDraft.harKulturfolkslag}}1{{else}}0{{/if}}" />
          <input type="hidden" name="ccw_folk_valfri_pool" value="{{folkValfriaPoolCsv}}" />
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-num">4</span><label class="eon-ccw-label" for="ccw_folkslag">{{localize "eon.sheets.actor.folkslag"}}</label>
            <select name="ccw_folkslag" id="ccw_folkslag">
                {{{folkslagOptionsHtml}}}
            </select>
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span><label class="eon-ccw-label" for="ccw_kulturfolkslag">{{localize "eon.sheets.actor.kulturfolkslag"}}</label>
            <select name="ccw_kulturfolkslag" id="ccw_kulturfolkslag" {{#unless kulturfolkslagSelectEnabled}}disabled{{/unless}}>
                {{{kulturfolkslagOptionsHtml}}}
            </select>
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
            <span class="eon-ccw-label" aria-hidden="true"></span>
            <p class="eon-ccw-hint eon-ccw-hint--in-field-column">{{localize "eon.wizard.folkKulturfolkslagHint"}}</p>
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-num">5</span><label class="eon-ccw-label" for="ccw_religion">{{localize "eon.sheets.actor.religion"}}</label>
            <input type="text" id="ccw_religion" name="ccw_religion" value="{{wizardDraft.religion}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
            <span class="eon-ccw-label" aria-hidden="true"></span>
            <p class="eon-ccw-hint eon-ccw-hint--in-field-column">{{localize "eon.wizard.doktrinRaderHint"}}</p>
          </div>
          {{#each doktrinRaderRows}}
            <div class="eon-ccw-row">
              <span class="eon-ccw-step-placeholder"></span>
              <label class="eon-ccw-label" for="ccw_doktrin_{{index}}_beskrivning">{{localize "eon.sheets.actor.doktrinRad"}}</label>
              <input type="text" id="ccw_doktrin_{{index}}_beskrivning" name="ccw_doktrin_{{index}}_beskrivning" value="{{beskrivning}}" />
              <button type="button" class="eon-ccw-icon-btn eon-ccw-doktrin-del" data-index="{{index}}" title="{{localize 'eon.sheets.actor.taBortDoktrinRad'}}" aria-label="{{localize 'eon.sheets.actor.taBortDoktrinRad'}}"><i class="fa-solid fa-trash-can"></i></button>
            </div>
          {{/each}}
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
            <span class="eon-ccw-label" aria-hidden="true"></span>
            <button type="button" class="eon-ccw-doktrin-add">{{localize "eon.sheets.actor.laggTillDoktrinRad"}}</button>
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-num">6</span><label class="eon-ccw-label" for="ccw_arketyp">{{localize "eon.sheets.actor.arketyp"}}</label>
            <input type="text" id="ccw_arketyp" name="ccw_arketyp" value="{{wizardDraft.arketyp}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span><label class="eon-ccw-label" for="ccw_varv">{{localize "eon.sheets.actor.varv"}}</label>
            <input type="text" id="ccw_varv" name="ccw_varv" value="{{wizardDraft.varv}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span><label class="eon-ccw-label" for="ccw_miljo">{{localize "eon.sheets.actor.miljo"}}</label>
            <input type="text" id="ccw_miljo" name="ccw_miljo" value="{{wizardDraft.miljo}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span><label class="eon-ccw-label" for="ccw_levnadsstandard">{{localize "eon.sheets.actor.levnadsstandard"}}</label>
            <input type="text" id="ccw_levnadsstandard" name="ccw_levnadsstandard" value="{{wizardDraft.levnadsstandard}}" />
          </div>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span><label class="eon-ccw-label" for="ccw_startkapital">{{localize "eon.sheets.actor.startkapital"}}</label>
            <input type="text" id="ccw_startkapital" name="ccw_startkapital" value="{{wizardDraft.startkapital}}" />
          </div>
        </div>
        <div class="eon-ccw-section">
          <div class="eon-ccw-section-title">{{localize "eon.sheets.actor.egenskaper"}}</div>
          <p class="eon-ccw-hint">{{localize "eon.wizard.egenskaperFolkslagHint"}}</p>
          <div class="eon-ccw-row">
            <span class="eon-ccw-step-placeholder"></span>
          </div>
          <div class="eon-ccw-subsection-title">{{localize "eon.wizard.folkEgenskaperObligatoriska"}}</div>
          <div class="eon-ccw-folk-egenskaper-list">
            {{#each folkEgenskapRows}}
            <div class="eon-ccw-folk-egenskap-row">
              <div class="eon-ccw-folk-egenskap-namn">{{label}}</div>
              <prose-mirror name="{{editFieldName}}" value="{{beskrivning}}" toggled compact>{{{beskrivningDisplay}}}</prose-mirror>
            </div>
            {{else}}
            <p class="eon-ccw-muted">{{localize "eon.wizard.folkEgenskaperIngenFolkslag"}}</p>
            {{/each}}
          </div>
          <div class="eon-ccw-subsection-title">{{localize "eon.wizard.folkEgenskaperValfria"}}</div>
          <p class="eon-ccw-hint">{{localize "eon.wizard.folkValfriaHint"}}</p>
          <div class="eon-ccw-folk-egenskaper-list eon-ccw-folk-valfria-checks">
            {{#each folkValfriaRows}}
            <div class="eon-ccw-folk-egenskap-row eon-ccw-folk-egenskap-row--valfri">
              <label class="eon-ccw-folk-valfri-label">
                <input type="checkbox" name="ccw_valfri" value="{{uuid}}" {{#if valfriChecked}}checked{{/if}} />
                <span class="eon-ccw-folk-egenskap-namn">{{label}}</span>
              </label>
              {{#if showProseMirror}}
              <prose-mirror name="{{editFieldName}}" value="{{beskrivning}}" toggled compact>{{{beskrivningDisplay}}}</prose-mirror>
              {{else}}
              <div class="eon-ccw-folk-egenskap-besk eon-ccw-folk-beskrivning-readonly">{{{beskrivningDisplay}}}</div>
              {{/if}}
            </div>
            {{else}}
            <p class="eon-ccw-muted">{{localize "eon.wizard.folkValfriaInga"}}</p>
            {{/each}}
          </div>
        </div>
      </div>
      {{/if}}

      {{#if tabHandelser}}
      <div class="eon-ccw-panel">
        <div class="eon-ccw-section">
          <div class="eon-ccw-section-title">{{localize "eon.wizard.handelseResultatRubrik"}}</div>
          <div class="eon-ccw-datagrid eon-ccw-datagrid--handelse">
            <div class="eon-ccw-datagrid__row eon-ccw-datagrid__row--head">
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-typ">{{localize "eon.sheets.actor.tabell"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-hash">{{localize "eon.wizard.handelseResultatNummer"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-beskrivning">{{localize "eon.sheets.actor.anteckning"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-actions" aria-hidden="true"></div>
            </div>
            {{#each handelseResultatRows}}
            <div class="eon-ccw-datagrid__row">
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--col-typ">{{{tabellOptionsHtml}}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--col-hash"><input type="text" name="ccw_hr_{{index}}_num" value="{{nummer}}" /></div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--col-beskrivning"><input type="text" name="ccw_hr_{{index}}_anteckning" value="{{anteckning}}" /></div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--col-actions">
                <button type="button" class="eon-ccw-icon-btn" data-action="ccwHandelseRemoveRow" data-handelse-index="{{index}}" title="{{localize 'eon.wizard.handelseTaBortRad'}}" aria-label="{{localize 'eon.wizard.handelseTaBortRad'}}"><i class="icon fa-solid fa-trash-can"></i></button>
              </div>
            </div>
            {{/each}}
          </div>
          <div class="eon-ccw-handelse-add-row">
            <button type="button" class="eon-ccw-btn-handelse-add" data-action="ccwHandelseAddRow">{{localize "eon.wizard.handelseLaggTillRad"}}</button>
          </div>
        </div>
      </div>
      {{/if}}

      {{#if tabGrundegenskaper}}
      <div class="eon-ccw-panel">
        <div class="eon-ccw-section">
          <div class="eon-ccw-section-title"><span class="eon-ccw-step-num">8</span>{{localize "eon.wizard.grundegenskaperFullRubrik"}}</div>
          <p class="eon-ccw-hint">{{localize "eon.wizard.grundegenskaperFullHint"}}</p>
          <div class="eon-ccw-datagrid eon-ccw-datagrid--attr">
            <div class="eon-ccw-datagrid__row eon-ccw-datagrid__row--head">
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-name">{{localize "eon.sheets.item.attribut"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-grund">{{localize "eon.sheets.actor.grund"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-grund">{{localize "eon.sheets.item.bonus"}}</div>
              <div class="eon-ccw-datagrid__cell eon-ccw-datagrid__cell--hdr eon-ccw-datagrid__cell--col-totalt">{{localize "eon.sheets.actor.totalt"}}</div>
            </div>
